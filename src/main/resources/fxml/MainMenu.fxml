<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="it.unicam.cs.mpgc.rpg130681.controller.fxml.MainMenuController">

    <VBox alignment="CENTER"
          spacing="20">

        <padding>
            <Insets top="40" bottom="40"/>
        </padding>

        <Label text="STAR SLAYER"/>

        <Button text="Gioca"
                prefWidth="250"
                onAction="#Play"/>

        <Button text="Carica partita"
                prefWidth="250"
                onAction="#Load"/>

        <Button text="Informazioni"
                prefWidth="250"
                onAction="#Info"/>

        <Button text="Esci"
                prefWidth="250"
                onAction="#Exit"/>

    </VBox>

</StackPane>