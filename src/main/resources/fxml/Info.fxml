<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="it.unicam.cs.mpgc.rpg130681.controller.fxml.InfoController">

    <VBox alignment="CENTER"
          spacing="15">

        <padding>
            <Insets top="40" bottom="40" left="80" right="80"/>
        </padding>

        <Label text="STAR SLAYER"/>

        <Label text="Distruggi pianeti per ottenere risorse."/>
        <Label text="Raccogli i drop e migliora la tua nave."/>
        <Label text="Evita le collisioni e sopravvivi."/>
        <Label text=""/>

        <Label text="CONTROLLI"/>
        <Label text="Space - Spara"/>
        <Label text="Mouse - Muoviti"/>
        <Label text="ESC - Pausa"/>

        <Button text="Indietro"
                prefWidth="250"
                onAction="#Back"/>

    </VBox>

</StackPane>